@node Memory Layout Constants
@appendixsec Memory Layout Constants

@vindex VM_PAGE_SIZE
@vindex VM_USER_LIMIT

@multitable @columnfractions .35 .20 .45
@headitem Constant @tab Value @tab Meaning
@item @code{HEAP_START} @tab @code{0x10000000} @tab Kernel heap start
@item @code{HEAP_SIZE} @tab @code{256 MiB} @tab Kernel heap size
@item @code{VM_PAGE_SIZE} @tab @code{0x1000} @tab Page size
@item @code{VM_USER_BASE} @tab @code{0x00400000} @tab Lowest user address
@item @code{VM_USER_STACK_TOP} @tab @code{0x08000000} @tab Initial user stack top
@item @code{VM_USER_STACK_SIZE} @tab @code{0x00200000} @tab Initial user stack size
