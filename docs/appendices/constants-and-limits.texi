@item @code{VM_USER_MMAP_BASE} @tab @code{0x0c000000} @tab Initial @code{mmap} base
@item @code{VM_USER_MMAP_LIMIT} @tab @code{0x0f000000} @tab Upper @code{mmap} limit
@item @code{VM_USER_ELF_LIMIT} @tab @code{0x20000000} @tab ELF image limit
@item @code{VM_USER_LIMIT} @tab @code{0x40000000} @tab Highest accepted user address
@end multitable

